data/
planetiler.jar

# Generated large map data — regenerate locally, never commit
# pedestrian-graph.db  (124.9 MB — exceeds GitHub 100 MB hard limit)
# pedestrian-graph.json (64 MB — generated by npm run generate-graph)
Likas/assets/maps/*.db
Likas/assets/maps/*.json

# Downloaded MapLibre glyph PBFs (regenerate via: node scripts/download-fonts.js)
**/assets/fonts/Noto Sans*/

# OS-specific
.DS_Store
Thumbs.db

